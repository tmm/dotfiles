#!/bin/sh
set -eu

if [ "$(uname -s)" != "Darwin" ]; then
  echo "bootstrap only supports macOS" >&2
  exit 1
fi

DOTFILES_HOME=${DOTFILES_HOME:-$(CDPATH= cd -- "$(dirname "$0")" && pwd)}
HOST_NAME=${1:-}

load_homebrew() {
  if command -v brew >/dev/null 2>&1; then
    return 0
  fi

  for brew_bin in /opt/homebrew/bin/brew /usr/local/bin/brew; do
    if [ -x "$brew_bin" ]; then
      eval "$($brew_bin shellenv)"
      return 0
    fi
  done

  return 1
}

install_nix() {
  installer="$(mktemp -t nix-installer.XXXXXX)"

  curl --proto '=https' --tlsv1.2 -fsSL https://nixos.org/nix/install -o "$installer"
  sh "$installer"

  rm -f "$installer"
}

ensure_nix_cert_file() {
  nix_ca_bundle=/nix/var/nix/profiles/default/etc/ssl/certs/ca-bundle.crt
  system_ca_bundle=/etc/ssl/certs/ca-certificates.crt

  [ -r "$nix_ca_bundle" ] || return 0

  sudo install -d -m 755 /etc/ssl /etc/ssl/certs

  if [ -L "$system_ca_bundle" ] && [ ! -e "$system_ca_bundle" ]; then
    echo "Removing broken CA bundle symlink $system_ca_bundle"
    sudo rm -f "$system_ca_bundle"
  fi

  if [ ! -e "$system_ca_bundle" ]; then
    echo "Linking $system_ca_bundle to Nix CA bundle"
    sudo ln -s "$nix_ca_bundle" "$system_ca_bundle"
  fi
}

path_exists() {
  [ -e "$1" ] || [ -L "$1" ]
}

ensure_fish_login_shell() {
  user_name=${SUDO_USER:-$(id -un)}
  fish_shell=/run/current-system/sw/bin/fish

  [ -x "$fish_shell" ] || return 0

  current_shell=$(dscl . -read "/Users/$user_name" UserShell 2>/dev/null | sed 's/^UserShell: //')

  [ -n "$current_shell" ] || return 0
  [ "$current_shell" = "$fish_shell" ] && return 0

  echo "Changing login shell for $user_name to $fish_shell"
  sudo chsh -s "$fish_shell" "$user_name"
}

is_nix_darwin_managed_symlink() {
  path="$1"

  [ -L "$path" ] || return 1

  case "$(readlink "$path")" in
    /etc/static/*|/nix/store/*)
      return 0
      ;;
  esac

  return 1
}

handoff_to_nix_darwin() {
  file="$1"
  backup="${file}.before-nix-darwin"

  path_exists "$file" || return 0

  if path_exists "$backup"; then
    echo "Removing temporary $file so nix-darwin can take ownership"
    sudo rm -f "$file"
    return 0
  fi

  echo "Moving $file to $backup so nix-darwin can take ownership"
  sudo mv "$file" "$backup"
}

prepare_etc_for_nix_darwin() {
  nix_ca_bundle=/nix/var/nix/profiles/default/etc/ssl/certs/ca-bundle.crt
  system_ca_bundle=/etc/ssl/certs/ca-certificates.crt

  if [ -L "$system_ca_bundle" ] && [ "$(readlink "$system_ca_bundle")" = "$nix_ca_bundle" ]; then
    handoff_to_nix_darwin "$system_ca_bundle"
  fi

  for file in /etc/bashrc /etc/zshrc; do
    path_exists "$file" || continue

    if is_nix_darwin_managed_symlink "$file"; then
      continue
    fi

    if [ -e "${file}.backup-before-nix" ] || contains_nix "$file" || { [ -f "$file" ] && [ ! -s "$file" ]; }; then
      handoff_to_nix_darwin "$file"
    fi
  done
}

contains_nix() {
  [ -f "$1" ] && grep -Eqi '(^# Nix$|nix-daemon\.sh|/nix|org\.nixos)' "$1"
}

sanitize_shell_file() {
  file="$1"

  awk '
    BEGIN {
      in_nix_block = 0
      in_nix_if = 0
    }

    in_nix_if {
      if ($0 ~ /^[[:space:]]*fi[[:space:]]*$/) {
        in_nix_if = 0
      }
      next
    }

    /^[[:space:]]*# Nix[[:space:]]*$/ {
      in_nix_block = 1
      next
    }

    in_nix_block {
      if ($0 ~ /^[[:space:]]*# End Nix[[:space:]]*$/) {
        in_nix_block = 0
      }
      next
    }

    /nix-daemon\.sh/ {
      if ($0 ~ /^[[:space:]]*if[[:space:]]+\[.*nix-daemon\.sh.*\][[:space:]]*;?[[:space:]]*then[[:space:]]*$/) {
        in_nix_if = 1
      }
      next
    }

    { print }
  ' "$file"
}

replace_file_from_sanitized_copy() {
  src="$1"
  dest="$2"
  tmp_file="$(mktemp)"

  sanitize_shell_file "$src" > "$tmp_file"

  if [ -s "$tmp_file" ]; then
    sudo install -m 644 "$tmp_file" "$dest"
  else
    sudo rm -f "$dest"
  fi

  rm -f "$tmp_file"
}

ensure_shell_profiles_exist() {
  sudo install -d -m 755 /etc/profile.d /etc/zsh

  for file in /etc/bashrc /etc/bash.bashrc /etc/zshrc /etc/zsh/zshrc; do
    if [ -L "$file" ] && [ ! -e "$file" ]; then
      echo "Removing broken shell profile symlink $file"
      sudo rm -f "$file"
    fi

    if [ ! -e "$file" ]; then
      echo "Creating missing shell profile $file"
      sudo install -m 644 /dev/null "$file"
    fi
  done
}

restore_shell_backup() {
  file="$1"
  backup="${file}.backup-before-nix"

  [ -e "$backup" ] || return 0

  if contains_nix "$backup"; then
    if [ ! -e "$file" ]; then
      echo "Restoring missing $file from sanitized $backup"
      replace_file_from_sanitized_copy "$backup" "$file"
      sudo rm -f "$backup"
      return 0
    fi

    if contains_nix "$file"; then
      echo "Restoring $file from sanitized $backup"
      replace_file_from_sanitized_copy "$backup" "$file"
      sudo rm -f "$backup"
      return 0
    fi

    echo "Removing polluted backup $backup"
    sudo rm -f "$backup"
    return 0
  fi

  if [ ! -e "$file" ]; then
    echo "Restoring missing $file from $backup"
    sudo mv "$backup" "$file"
    return 0
  fi

  if contains_nix "$file"; then
    echo "Restoring $file from $backup"
    sudo mv "$backup" "$file"
  else
    echo "Removing stale backup $backup"
    sudo rm -f "$backup"
  fi
}

cleanup_fstab() {
  [ -f /etc/fstab ] || return 0

  tmp_file="$(mktemp)"
  sudo awk '!/\/nix[[:space:]]/ && !/Nix\\040Store/' /etc/fstab > "$tmp_file"

  if ! cmp -s "$tmp_file" /etc/fstab; then
    echo "Removing Nix entries from /etc/fstab"
    if [ -s "$tmp_file" ]; then
      sudo cp "$tmp_file" /etc/fstab
    else
      sudo rm -f /etc/fstab
    fi
  fi

  rm -f "$tmp_file"
}

cleanup_synthetic_conf() {
  [ -f /etc/synthetic.conf ] || return 0

  tmp_file="$(mktemp)"
  sudo awk '$0 != "nix"' /etc/synthetic.conf > "$tmp_file"

  if ! cmp -s "$tmp_file" /etc/synthetic.conf; then
    echo "Removing Nix entries from /etc/synthetic.conf"
    if [ -s "$tmp_file" ]; then
      sudo cp "$tmp_file" /etc/synthetic.conf
    else
      sudo rm -f /etc/synthetic.conf
    fi
  fi

  rm -f "$tmp_file"
}

needs_nix_reset() {
  for file in /etc/zshrc /etc/bashrc /etc/bash.bashrc; do
    if [ -e "${file}.backup-before-nix" ]; then
      return 0
    fi
  done

  for plist in \
    /Library/LaunchDaemons/org.nixos.nix-daemon.plist \
    /Library/LaunchDaemons/org.nixos.darwin-store.plist
  do
    if [ -e "$plist" ]; then
      return 0
    fi
  done

  if [ -d /nix ]; then
    return 0
  fi

  if [ -f /etc/fstab ] && grep -Eq '/nix[[:space:]]|Nix\\040Store' /etc/fstab; then
    return 0
  fi

  if [ -f /etc/synthetic.conf ] && grep -qx 'nix' /etc/synthetic.conf; then
    return 0
  fi

  return 1
}

reset_partial_nix_install() {
  echo "Resetting partial Nix install state..."
  sudo -v

  for file in /etc/zshrc /etc/bashrc /etc/bash.bashrc; do
    restore_shell_backup "$file"
  done

  for plist in \
    /Library/LaunchDaemons/org.nixos.nix-daemon.plist \
    /Library/LaunchDaemons/org.nixos.darwin-store.plist
  do
    if [ -e "$plist" ]; then
      echo "Removing $plist"
      sudo launchctl unload "$plist" 2>/dev/null || true
      sudo rm -f "$plist"
    fi
  done

  for user in $(sudo dscl . -list /Users 2>/dev/null | grep '^_nixbld' || true); do
    echo "Removing user $user"
    sudo dscl . -delete "/Users/$user" 2>/dev/null || true
  done

  if sudo dscl . -read /Groups/nixbld >/dev/null 2>&1; then
    echo "Removing group nixbld"
    sudo dscl . -delete /Groups/nixbld 2>/dev/null || true
  fi

  cleanup_fstab
  cleanup_synthetic_conf

  echo "Removing Nix config and profiles"
  sudo rm -rf /etc/nix /var/root/.nix-profile /var/root/.nix-defexpr /var/root/.nix-channels
  rm -rf "$HOME/.nix-profile" "$HOME/.nix-defexpr" "$HOME/.nix-channels"

  echo "Removing Nix Store volume if present"
  sudo diskutil apfs deleteVolume /nix 2>/dev/null || true

  if diskutil list | grep -q 'Nix Store'; then
    disk_id="$(diskutil list | awk '/Nix Store/ { print $NF; exit }')"
    if [ -n "$disk_id" ]; then
      sudo diskutil apfs deleteVolume "$disk_id" 2>/dev/null || true
    fi
  fi

  echo "Reset complete. Reboot if /nix still exists, then rerun ./bootstrap <host>."
}

if [ -z "$HOST_NAME" ]; then
  echo "Usage: ./bootstrap <host>" >&2
  exit 1
fi

if ! xcode-select -p >/dev/null 2>&1; then
  echo "Installing Xcode Command Line Tools..."
  xcode-select --install || true
  echo "Finish the Command Line Tools install, then rerun ./bootstrap." >&2
  exit 1
fi

load_homebrew || true

if ! command -v brew >/dev/null 2>&1; then
  echo "Installing Homebrew..."
  /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
  load_homebrew || true
fi

if ! command -v nix >/dev/null 2>&1 && [ -r /nix/var/nix/profiles/default/etc/profile.d/nix-daemon.sh ]; then
  . /nix/var/nix/profiles/default/etc/profile.d/nix-daemon.sh
fi

if ! command -v nix >/dev/null 2>&1; then
  if needs_nix_reset; then
    echo "Cleaning up artifacts from a previous Nix install attempt..."
    reset_partial_nix_install
  fi

  ensure_shell_profiles_exist

  echo "Installing Nix..."
  install_nix
fi

if ! command -v nix >/dev/null 2>&1 && [ -r /nix/var/nix/profiles/default/etc/profile.d/nix-daemon.sh ]; then
  . /nix/var/nix/profiles/default/etc/profile.d/nix-daemon.sh
fi

if ! command -v nix >/dev/null 2>&1; then
  echo "Nix is installed but not available in this shell. Open a new shell and rerun ./bootstrap." >&2
  exit 1
fi

ensure_nix_cert_file

if [ -r /nix/var/nix/profiles/default/etc/ssl/certs/ca-bundle.crt ]; then
  export NIX_SSL_CERT_FILE=/nix/var/nix/profiles/default/etc/ssl/certs/ca-bundle.crt
  export SSL_CERT_FILE=$NIX_SSL_CERT_FILE
fi

if [ ! -e /etc/synthetic.conf ]; then
  sudo install -m 644 /dev/null /etc/synthetic.conf
fi

prepare_etc_for_nix_darwin

sudo -H env \
  NIX_SSL_CERT_FILE="${NIX_SSL_CERT_FILE:-}" \
  SSL_CERT_FILE="${SSL_CERT_FILE:-}" \
  nix --extra-experimental-features "nix-command flakes" \
  run nix-darwin -- switch --flake "path:$DOTFILES_HOME/nix#$HOST_NAME"

ensure_fish_login_shell

if [ -t 0 ] && [ -t 1 ] && [ -x /run/current-system/sw/bin/fish ] && [ "${SHELL:-}" != /run/current-system/sw/bin/fish ]; then
  echo "Starting fish for this terminal..."
  exec /run/current-system/sw/bin/fish -l
fi
